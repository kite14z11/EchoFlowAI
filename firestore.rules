rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidSession(data) {
      return data.userId is string && data.userId == request.auth.uid
        && data.title is string && data.title.size() <= 500
        && data.date is string
        && data.originalText is string && data.originalText.size() <= 20000
        && data.transcript is string && data.transcript.size() <= 20000
        && data.feedback is string && data.feedback.size() <= 20000
        && data.score is int
        && data.practiceItems is list
        && data.voiceSettings is map
        && data.voiceSettings.voiceName is string
        && data.voiceSettings.tone is string
        && data.voiceSettings.speed is number;
    }

    // Sessions collection
    match /sessions/{sessionId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(sessionId)
        && isValidSession(request.resource.data)
        && request.resource.data.createdAt == request.time;

      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && isValidSession(request.resource.data)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.createdAt == resource.data.createdAt
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'originalText', 'transcript', 'feedback', 'score', 'voiceSettings'])
        );
        
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
